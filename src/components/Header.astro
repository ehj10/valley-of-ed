---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/valley-of-ed/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
	<HeaderLink href="/valley-of-ed/blog">Essays</HeaderLink>
	<HeaderLink href="/valley-of-ed/music">Music</HeaderLink>
	<HeaderLink href="/valley-of-ed/career">Career</HeaderLink>
</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: ##868686;
		border-bottom: 1px solid #1e2028;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #ffffff;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(160, 170, 190);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: #a8b5ff;
		color: #ffffff;
	}
	nav a:hover {
	color: #ffffff;
	font-family: 'Wingdings', sans-serif;
}
</style>
