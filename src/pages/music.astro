---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Music | ${SITE_TITLE}`} description="Music produced by Valley of Ed." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Music</h1>
			<p>
				Made in Ableton, built for personal exploration.
			</p>
			<div class="tracks">
				<iframe 
					width="100%" 
					height="300" 
					scrolling="no" 
					frameborder="no" 
					allow="autoplay" 
					src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/soundcloud%253Atracks%253A2296791278&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true">
				</iframe>
				<div class="track-credit">
					<a href="https://soundcloud.com/ed-partial" target="_blank">ed partial</a> · 
					<a href="https://soundcloud.com/ed-partial/7-27-25_clip" target="_blank">7.27.25_clip</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.tracks {
		margin-top: 2em;
		display: flex;
		flex-direction: column;
		gap: 2em;
	}
	.track-credit {
		font-size: 0.75em;
		color: rgb(var(--gray));
		margin-top: 0.5em;
	}
	.track-credit a {
		color: rgb(var(--gray));
	}
</style>